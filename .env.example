# ==============================================================================
# Auto-Bewerbung System — Environment Variables Template
# ==============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to Git — it is already in .gitignore
# ==============================================================================

# --- Google Maps Platform ---
# Get your key at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# --- Gmail SMTP / IMAP ---
# Use a Gmail App Password (NOT your main Gmail password).
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Applicant Personal Details ---
# These populate the body and signature of every outgoing email.
APPLICANT_NAME=
APPLICANT_ADDRESS=
APPLICANT_PHONE=
APPLICANT_EMAIL=

# --- CV Configuration ---
# Filename of your CV PDF. Must exist in the project root directory.
CV_FILENAME=CV.pdf

# --- Campaign Settings ---
# Maximum number of emails sent per execution run (safety limit).
DAILY_EMAIL_LIMIT=20

# --- Search Configuration (optional overrides) ---
# Comma-separated list of business keywords to search for.
# Default is defined in src/config.py — only set this to override.
# SEARCH_KEYWORDS=Restaurant,Hotel,Cafe,Logistik,Lager

# Comma-separated list of Berlin districts to target.
# SEARCH_DISTRICTS=Mitte Berlin,Kreuzberg Berlin,Neukölln Berlin
